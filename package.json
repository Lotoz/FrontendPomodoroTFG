{
  "name": "pomodoro-war",
  "version": "1.0.0",
  "main": "dist-electron/main.js",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "app:build": "vite build && electron-builder"
  },
  "build": {
    "appId": "com.tuusuario.pomodorowar",
    "productName": "Pomodoro War",
    "directories": {
      "output": "release"
    },
    "extraResources": [
      {
        "from": "electron/backend.jar",
        "to": "backend.jar",
        "filter": [
          "**/*"
        ]
      }
    ],
    "win": {
      "icon": "electron/icons/icon.ico",
      "target": [
        "nsis"
      ]
    },
    "linux": {
      "icon": "electron/icons/icon.png",
      "target": [
        "AppImage"
      ]
    }
  }
}
