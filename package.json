{
  "name": "pomodoro-war",
  "version": "1.0.0",
  "main": "dist-electron/main.js",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "app:build": "vite build && electron-builder"
  },
  "dependencies": {
    "axios": "^1.7.0",
    "pinia": "^2.1.7",
    "vue": "^3.4.0",
    "vue-router": "^4.3.0"
  },
  "devDependencies": {
    "@vitejs/plugin-vue": "^5.2.1",
    "electron": "^30.0.0",
    "electron-builder": "^24.13.3",
    "vite": "^6.0.0",
    "vite-plugin-electron": "^0.28.0"
  },
  "build": {
    "appId": "com.lotoz.pomodorowar",
    "productName": "Pomodoro War",
    "directories": {
      "output": "release"
    },
    "extraResources": [
      {
        "from": "electron/backend.jar",
        "to": "backend.jar",
        "filter": [
          "**/*"
        ]
      }
    ],
    "win": {
      "icon": "electron/icons/icon.ico",
      "target": [
        "nsis"
      ]
    },
    "linux": {
      "icon": "electron/icons/icon.png",
      "target": [
        "AppImage"
      ]
    }
  }
}
